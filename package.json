{
  "name": "rtl-forge",
  "version": "0.2.0",
  "private": false,
  "description": "RTL runtime for official Claude Desktop + Codex on macOS \u2014 no copy/patch/re-sign. Original work by Menachem Samama.",
  "license": "MIT",
  "author": "Menachem Samama",
  "repository": {
    "type": "git",
    "url": "https://github.com/Menachem138/rtl-forge.git"
  },
  "bugs": {
    "url": "https://github.com/Menachem138/rtl-forge/issues"
  },
  "homepage": "https://github.com/Menachem138/rtl-forge#readme",
  "type": "commonjs",
  "scripts": {
    "test": "node --test payload-v2/test/*.test.js manager/__tests__/*.test.js",
    "build": "node payload-v2/build.mjs",
    "official:launch": "official-runtime/macos/launch-rtl-forge.sh",
    "official:ensure": "official-runtime/macos/ensure-rtl-forge.sh --force",
    "official:watch": "official-runtime/macos/install-watchdog.sh",
    "official:unwatch": "official-runtime/macos/uninstall-watchdog.sh",
    "manager:build": "manager/gui/build.sh",
    "manager:status": "manager/core/app-status.sh",
    "codex:apply": "official-runtime/macos/apply-electron-rtl.sh /Applications/ChatGPT.app auto codex-research-macos",
    "hermes:apply": "official-runtime/macos/apply-electron-rtl.sh /Applications/Hermes.app auto hermes-electron-macos"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "codex",
    "rtl",
    "hebrew",
    "arabic",
    "macos",
    "accessibility",
    "electron"
  ]
}
